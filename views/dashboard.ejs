<%- include('partials/header.ejs') %>
<title>Dashboard | StockMate</title>
<style>
/* Dashboard Specific Layout Details */
.dashboard-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 0;
}

.hero-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
}
.hero-greeting {
    font-size: 24px;
    font-weight: 500;
}
.hero-subtitle {
    font-size: 14px;
    color: var(--text-muted);
    margin-top: 4px;
}
.hero-actions {
    display: flex;
    gap: 12px;
}

.kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
}
.kpi-card {
    padding: 1rem;
}
.kpi-label {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.kpi-value {
    font-size: 24px;
    font-weight: 500;
}
.kpi-indicator {
    font-size: 12px;
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 4px;
}
.indicator-positive { color: var(--success); }
.indicator-warning { color: var(--warning); }

.middle-split {
    display: grid;
    grid-template-columns: 3fr 2fr; /* 60/40 Split */
    gap: 2rem;
    margin-bottom: 2rem;
}

.section-title {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 1rem;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-color);
}

.feed-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
}
.feed-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
}
.feed-dot {
    margin-top: 4px;
    width: 8px;
    height: 8px;
    background: var(--primary-accent);
    border-radius: 50%;
}
.feed-text { font-size: 14px; color: var(--text-primary); }
.feed-time { font-size: 12px; color: var(--text-muted); }

.capacity-bar-wrap {
    margin-bottom: 1.5rem;
}
.cap-title {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    margin-bottom: 6px;
}
.cap-track {
    width: 100%;
    height: 8px;
    background-color: #e2e8f0;
    border-radius: 4px;
    overflow: hidden;
}
.cap-fill {
    height: 100%;
    background-color: var(--primary-accent);
    width: 65%; /* Dummy data */
    border-radius: 4px;
}

.low-stock-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.ls-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-color);
}
.ls-badge {
    background-color: #fef3c7;
    color: var(--warning);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 12px;
}

.quick-actions-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}
.action-card {
    cursor: pointer;
    transition: transform 150ms ease, border-color 150ms ease;
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.action-card:hover {
    transform: translateY(-2px);
    border-color: #cbd5e1;
}
.action-icon {
    font-size: 20px;
    color: var(--primary-accent);
    margin-bottom: 4px;
}
.action-title {
    font-weight: 500;
    font-size: 15px;
    display: flex;
    justify-content: space-between;
}
.action-desc {
    font-size: 13px;
    color: var(--text-muted);
}
.action-arrow { color: #cbd5e1; }
</style>

<div class="dashboard-container">
    <div class="hero-section">
        <div>
            <h1 class="hero-greeting"><%= greeting %>, <%= name %></h1>
            <p class="hero-subtitle">Here's what's happening in your warehouse today.</p>
        </div>
        <div class="hero-actions">
            <button class="btn-primary" onclick="openDashAddModal()">Add Product</button>
            <button class="btn-outlined" onclick="window.location.href='/makeInv'">Configure Warehouse</button>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="card kpi-card">
            <div class="kpi-label">Total Products</div>
            <div class="kpi-value"><%= totalProducts.toLocaleString() %></div>
            <div class="kpi-indicator indicator-positive"><i class="fa-solid fa-boxes-stacked"></i> Across all warehouses</div>
        </div>
        <div class="card kpi-card">
            <div class="kpi-label">Space Utilized</div>
            <div class="kpi-value"><%= spacePercent %>%</div>
            <div class="kpi-indicator <%= spaceHealthClass %>"><i class="fa-solid fa-warehouse"></i> <%= spaceHealth %></div>
        </div>
        <div class="card kpi-card">
            <div class="kpi-label">Low Stock Alerts</div>
            <div class="kpi-value"><%= lowStockCount %></div>
            <div class="kpi-indicator <%= lowStockCount > 0 ? 'indicator-warning' : 'indicator-positive' %>">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <%= lowStockCount > 0 ? 'Requires attention' : 'All stocked' %>
            </div>
        </div>
        <div class="card kpi-card">
            <div class="kpi-label">Active Bins</div>
            <div class="kpi-value"><%= totalBins %></div>
            <div class="kpi-indicator indicator-positive"><i class="fa-solid fa-boxes-stacked"></i> <%= freeBins %> free bins</div>
        </div>
    </div>

    <div class="middle-split">
        <div class="card">
            <div class="section-title">Recent Activity</div>
            <ul class="feed-list">
                <% if (activityLog && activityLog.length > 0) { %>
                    <% activityLog.forEach(function(log) { %>
                    <li class="feed-item">
                        <div class="feed-dot" style="background:<%= log.dotColor %>"></div>
                        <div>
                            <div class="feed-text"><%= log.action %><% if(log.detail) { %> — <span style="color:var(--text-muted);"><%= log.detail %></span><% } %></div>
                            <div class="feed-time"><%= log.timeAgo %></div>
                        </div>
                    </li>
                    <% }) %>
                <% } else { %>
                    <li style="text-align:center; padding:2rem 0; color:var(--text-muted); font-size:13px;">
                        No activity yet. Add products or reorganize bins to see real logs here.
                    </li>
                <% } %>
            </ul>
        </div>

        <div class="card">
            <div class="section-title">Quick Stats</div>
            
            <div class="capacity-bar-wrap">
                <div class="cap-title">
                    <span>Warehouse Capacity</span>
                    <strong><%= spacePercent %>%</strong>
                </div>
                <div class="cap-track">
                    <div class="cap-fill" style="width:<%= spacePercent %>%; background:<%= spacePercent > 85 ? 'var(--danger)' : spacePercent > 65 ? 'var(--warning)' : 'var(--primary-accent)' %>;"></div>
                </div>
            </div>

            <div class="cap-title" style="margin-top:2rem;">
                <span>Low Stock Items</span>
            </div>
            <div class="low-stock-list">
                <% if (lowStockItems && lowStockItems.length > 0) { %>
                    <% lowStockItems.forEach(function(item) { %>
                    <div class="ls-item">
                        <span style="font-size:14px;"><%= item.name %></span>
                        <span class="ls-badge"><%= item.quantity %> left</span>
                    </div>
                    <% }) %>
                <% } else { %>
                    <div style="font-size:13px; color:var(--text-muted); padding:8px 0;">No low-stock items — all quantities healthy.</div>
                <% } %>
            </div>
            <a href="/inventory" style="display:block; margin-top:16px; font-size:13px; color:var(--primary-accent);">View all inventory &rarr;</a>
        </div>
    </div>

    <div class="quick-actions-row">
        <div class="card action-card" onclick="openDashAddModal()">
            <div class="action-icon"><i class="fa-solid fa-plus-circle"></i></div>
            <div class="action-title">Add New Product <span class="action-arrow">&rarr;</span></div>
            <div class="action-desc">Log incoming inventory using predictive capacity algos.</div>
        </div>
        <div class="card action-card" onclick="openModal('searchModal')">
            <div class="action-icon"><i class="fa-solid fa-magnifying-glass"></i></div>
            <div class="action-title">Search Product <span class="action-arrow">&rarr;</span></div>
            <div class="action-desc">O(1) Hash lookups to locate items physically within seconds.</div>
        </div>
        <div class="card action-card" onclick="openModal('reorgModal')">
            <div class="action-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
            <div class="action-title">Reorganize Bins <span class="action-arrow">&rarr;</span></div>
            <div class="action-desc">Optimize spatial distribution inside existing hardware.</div>
        </div>
    </div>
</div>

<!-- ========================================== -->
<!-- FEATURE 1: ADD PRODUCT MODAL (Warehouse dropdown + Single/CSV tabs) -->
<!-- ========================================== -->
<div class="modal-overlay" id="addModal" style="display:none;">
    <div class="modal-box" style="max-width:560px; width:100%; position:relative;">

        <!-- Header -->
        <div style="display:flex; justify-content:space-between; align-items:center; padding-bottom:1rem; border-bottom:1px solid var(--border-color); margin-bottom:1.25rem;">
            <div>
                <div style="font-size:16px; font-weight:500; color:var(--text-primary);">Add Products</div>
                <div style="font-size:12px; color:var(--text-muted); margin-top:2px;">Select a warehouse and add inventory</div>
            </div>
            <button onclick="closeModal('addModal')" style="background:none;border:none;font-size:18px;cursor:pointer;color:var(--text-muted);"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <!-- Warehouse Dropdown -->
        <div class="form-group" style="margin-bottom:1.25rem;">
            <label style="display:flex; align-items:center; gap:6px; font-size:12px; font-weight:500; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:8px;">
                <i class="fa-solid fa-warehouse" style="color:var(--primary-accent);"></i> Warehouse
            </label>
            <div style="position:relative;">
                <select id="dashWhSelect" class="form-input" style="width:100%; padding:10px 12px 10px 36px; border:1px solid var(--border-color); border-radius:8px; font-size:14px; box-sizing:border-box; background:#fff; appearance:none; cursor:pointer;" onchange="onDashWhChange()">
                    <option value="">— Select a warehouse —</option>
                </select>
                <i class="fa-solid fa-warehouse" style="position:absolute; left:11px; top:50%; transform:translateY(-50%); color:var(--primary-accent); pointer-events:none; font-size:13px;"></i>
                <i class="fa-solid fa-chevron-down" style="position:absolute; right:12px; top:50%; transform:translateY(-50%); color:var(--text-muted); pointer-events:none; font-size:11px;"></i>
            </div>
            <!-- Capacity mini-bar for selected warehouse -->
            <div id="dashWhCapBar" style="display:none; margin-top:8px; background:#f8fafc; border:1px solid var(--border-color); border-radius:6px; padding:8px 12px;">
                <div style="display:flex; justify-content:space-between; font-size:12px; color:var(--text-secondary); margin-bottom:5px;">
                    <span id="dashWhCapLabel">Utilization</span>
                    <span id="dashWhCapPct">0%</span>
                </div>
                <div style="height:5px; background:#e2e8f0; border-radius:3px; overflow:hidden;">
                    <div id="dashWhCapFill" style="height:100%; border-radius:3px; background:var(--primary-accent); width:0%; transition:width 300ms ease;"></div>
                </div>
                <div style="font-size:11px; color:var(--text-muted); margin-top:5px;">Available: <strong id="dashWhAvailSpace" style="color:var(--text-primary);">—</strong> m³ &nbsp;|&nbsp; Free bins: <strong id="dashWhFreeBins" style="color:var(--text-primary);">—</strong></div>
            </div>
        </div>

        <!-- Mode Tabs -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:1.25rem;">
            <button id="dashTabSingle" onclick="dashSwitchTab('single')" class="btn-primary" style="font-size:13px; padding:8px;">
                <i class="fa-solid fa-plus"></i> Add Single Product
            </button>
            <button id="dashTabCSV" onclick="dashSwitchTab('csv')" class="btn-outlined" style="font-size:13px; padding:8px;">
                <i class="fa-solid fa-file-csv"></i> Bulk CSV Upload
            </button>
        </div>

        <!-- ── SINGLE PRODUCT FORM ─────────────────────────────── -->
        <div id="dashPanelSingle">
            <div id="dashSingleResult" style="display:none; padding:10px 14px; border-radius:8px; margin-bottom:1rem; font-size:13px;"></div>
            <form id="dashSingleForm" style="display:flex; flex-direction:column; gap:12px;">
                <input type="hidden" id="dashSpWarehouseId">
                <div class="form-group">
                    <label>Product Name <span style="color:var(--danger);">*</span></label>
                    <input type="text" class="form-input" id="dashSpName" placeholder="e.g. Steel Bearings" required>
                </div>
                <div class="form-group">
                    <label>SKU</label>
                    <input type="text" class="form-input" id="dashSpSku" placeholder="e.g. SKU-001">
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <div class="form-group">
                        <label>Quantity <span style="color:var(--danger);">*</span></label>
                        <input type="number" class="form-input" id="dashSpQty" min="1" placeholder="100" required>
                    </div>
                    <div class="form-group">
                        <label>Priority</label>
                        <select class="form-input" id="dashSpPriority">
                            <option value="High">High</option>
                            <option value="Medium" selected>Medium</option>
                            <option value="Low">Low</option>
                        </select>
                    </div>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <div class="form-group">
                        <label>Size (m²/unit) <span style="color:var(--danger);">*</span></label>
                        <input type="number" class="form-input" id="dashSpSize" step="any" min="0.01" placeholder="0.5" required>
                    </div>
                    <div class="form-group">
                        <label>Weight (kg/unit)</label>
                        <input type="number" class="form-input" id="dashSpWeight" step="any" min="0" placeholder="2.0">
                    </div>
                </div>

                <!-- Live space + capacity preview -->
                <div id="dashSpPreview" style="display:none; background:#f8fafc; border:1px solid var(--border-color); border-radius:8px; padding:12px 14px; font-size:13px; color:var(--text-secondary);">
                    <div style="font-weight:600; margin-bottom:8px; color:var(--text-primary);"><i class="fa-solid fa-chart-pie" style="color:var(--primary-accent);"></i> Predictive Capacity Preview</div>
                    <div style="display:flex; justify-content:space-between; margin-bottom:4px;">
                        <span>Space Required:</span>
                        <strong id="dashSpSpaceVal" style="color:var(--text-primary);">—</strong>
                    </div>
                    <div style="display:flex; justify-content:space-between; margin-bottom:4px;">
                        <span>Warehouse Available:</span>
                        <strong id="dashSpAvailVal" style="color:var(--success);">—</strong>
                    </div>
                    <div id="dashSpFitMsg" style="font-style:italic; font-size:12px; color:#64748b; margin-top:6px;">Knapsack resolver localizes to selected warehouse.</div>
                </div>

                <button type="button" onclick="dashSubmitSingleProduct()" class="btn-primary" style="width:100%;">
                    <i class="fa-solid fa-arrow-right-to-bracket"></i> Add to Warehouse
                </button>
            </form>
        </div>

        <!-- ── CSV BULK UPLOAD ─────────────────────────────────── -->
        <div id="dashPanelCSV" style="display:none; flex-direction:column; gap:14px;">
            <!-- Template download -->
            <div style="background:#EFF6FF; border:1px solid #bfdbfe; border-radius:8px; padding:12px 14px; display:flex; align-items:center; justify-content:space-between; gap:12px;">
                <div>
                    <div style="font-size:13px; font-weight:500; color:#1e40af;">CSV Template</div>
                    <div style="font-size:12px; color:#3b82f6; margin-top:2px;">name, quantity, size, weight, priority (High/Medium/Low), warehouse</div>
                </div>
                <a href="/inventory/csv-template" download="stockmate_template.csv" class="btn-outlined" style="text-decoration:none; font-size:12px; white-space:nowrap; padding:7px 12px;">
                    <i class="fa-solid fa-download"></i> Download
                </a>
            </div>

            <div id="dashCsvResult" style="display:none; padding:10px 14px; border-radius:8px; font-size:13px;"></div>

            <!-- Drop zone -->
            <div id="dashCsvDropZone" style="border:2px dashed var(--border-color); border-radius:10px; padding:2rem; text-align:center; cursor:pointer; transition:all 200ms ease; position:relative;">
                <i class="fa-solid fa-file-arrow-up" style="font-size:28px; color:var(--text-muted); margin-bottom:10px; display:block;"></i>
                <div style="font-size:14px; font-weight:500; color:var(--text-primary);">Drop your CSV file here</div>
                <div style="font-size:12px; color:var(--text-muted); margin-top:4px;">or click to browse</div>
                <input type="file" id="dashCsvFileInput" accept=".csv" style="position:absolute;inset:0;opacity:0;cursor:pointer;">
            </div>
            <div id="dashCsvFileName" style="font-size:12px; color:var(--text-muted); display:none;">
                <i class="fa-solid fa-file-csv" style="color:var(--success);"></i> <span id="dashCsvFileNameText"></span>
            </div>

            <!-- Preview table -->
            <div id="dashCsvPreviewWrap" style="display:none;">
                <div style="font-size:12px; color:var(--text-secondary); margin-bottom:6px;">Preview (first 5 rows):</div>
                <div style="overflow-x:auto; border:1px solid var(--border-color); border-radius:8px;">
                    <table style="width:100%; border-collapse:collapse; font-size:12px;">
                        <thead><tr id="dashCsvPreviewHead" style="background:#f8fafc;"></tr></thead>
                        <tbody id="dashCsvPreviewBody"></tbody>
                    </table>
                </div>
            </div>

            <button type="button" id="dashCsvSubmitBtn" onclick="dashSubmitCSV()" class="btn-primary" style="width:100%; display:none;">
                <i class="fa-solid fa-cloud-arrow-up"></i> Upload &amp; Allocate All Products
            </button>
        </div>

    </div>
</div>
<style>
#dashCsvDropZone.drag-over { border-color:var(--primary-accent); background:#EFF6FF; }
</style>


<!-- ========================================== -->
<!-- FEATURE 2: SEARCH PRODUCT MODAL -->
<!-- ========================================== -->
<div class="modal-overlay" id="searchModal">
    <div class="modal-box" style="position:relative;">
        <button class="modal-close" onclick="closeModal('searchModal')" style="position:absolute; top:1.5rem; right:1.5rem; background:none; border:none; font-size:20px; cursor:pointer;" aria-label="Close"><i class="fa-solid fa-xmark"></i></button>
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:1.5rem;">
            <div class="section-title" style="font-size:18px; margin:0; border:none;">Search Product</div>
            <span style="background:#E6F1FB; color:#185FA5; font-size:11px; border-radius:99px; padding:2px 8px; font-weight:500;">⚡ O(1) Hash Lookup</span>
        </div>
        
        <form id="searchForm" style="display:flex; gap:8px; margin-bottom:1.5rem;">
            <input type="text" id="searchInput" class="form-input" placeholder="Enter product name or SKU..." required style="flex:1; padding:10px 12px; border:1px solid #e2e8f0; border-radius:8px; font-size:14px; box-sizing:border-box;">
            <button type="submit" style="background:#378ADD; color:white; padding:0 20px; border:none; border-radius:8px; font-size:14px; font-weight:500; cursor:pointer;">Search</button>
        </form>

        <div id="searchResultArea" style="min-height:100px;">
            <div id="searchEmpty" style="text-align:center; color:#64748b; font-size:14px; padding:2rem 0;">Enter a product name or SKU to locate it instantly</div>
            <div id="searchLoader" style="display:none; text-align:center; padding:2rem 0;"><i class="fa-solid fa-circle-notch fa-spin" style="color:#378ADD; font-size:24px;"></i></div>
            <div id="searchNotFound" style="display:none; text-align:center; color:#A32D2D; font-size:14px; padding:2rem 0; background:#fef2f2; border-radius:8px;">No product found matching that query.</div>
            
            <div id="searchFoundList" style="display:none; flex-direction:column; gap:12px; max-height:400px; overflow-y:auto;">
                <!-- Result array items get injected here -->
            </div>
        </div>
    </div>
</div>

<!-- ========================================== -->
<!-- FEATURE 3: REORGANIZE BINS MODAL -->
<!-- ========================================== -->
<div class="modal-overlay" id="reorgModal">
    <div class="modal-box" style="position:relative;">
        <button class="modal-close" onclick="if(!isReorgRunning) closeModal('reorgModal')" style="position:absolute; top:1.5rem; right:1.5rem; background:none; border:none; font-size:20px; cursor:pointer;" aria-label="Close"><i class="fa-solid fa-xmark"></i></button>
        <div class="section-title" style="font-size:18px; margin:0 0 8px 0; border:none;">Reorganize Bins</div>
        <p style="font-size:13px; color:#64748b; margin-bottom:1.5rem; line-height:1.5;">Runs the 0/1 Knapsack Algorithm to redistribute all products across bins for maximum space efficiency.</p>
        
        <div id="reorgPreState" style="display:block;">
            <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:12px; margin-bottom:1.5rem;">
                <div style="background:#f8fafc; padding:12px; border-radius:8px; border:1px solid #e2e8f0; text-align:center;">
                    <div style="font-size:11px; color:#64748b; text-transform:uppercase;">Total Products</div>
                    <div style="font-size:20px; font-weight:600; color:#0f172a;" id="reorgProdCount"><i class="fa-solid fa-spinner fa-spin text-sm"></i></div>
                </div>
                <div style="background:#f8fafc; padding:12px; border-radius:8px; border:1px solid #e2e8f0; text-align:center;">
                    <div style="font-size:11px; color:#64748b; text-transform:uppercase;">Total Bins</div>
                    <div style="font-size:20px; font-weight:600; color:#0f172a;" id="reorgBinCount"><i class="fa-solid fa-spinner fa-spin text-sm"></i></div>
                </div>
                <div style="background:#f8fafc; padding:12px; border-radius:8px; border:1px solid #e2e8f0; text-align:center;">
                    <div style="font-size:11px; color:#64748b; text-transform:uppercase;">Avg Util %</div>
                    <div style="font-size:20px; font-weight:600; color:#0f172a;" id="reorgUtil"><i class="fa-solid fa-spinner fa-spin text-sm"></i></div>
                </div>
            </div>
            
            <button id="runReorgBtn" style="background:#378ADD; color:white; width:100%; padding:11px; border:none; border-radius:8px; font-size:14px; font-weight:500; cursor:pointer; margin-bottom:12px;" onclick="executeReorg()">Run Optimization</button>
            <div style="background:#FAEEDA; color:#854F0B; padding:10px 12px; border-radius:8px; font-size:12px; display:flex; gap:8px;">
                <i class="fa-solid fa-triangle-exclamation" style="margin-top:2px;"></i>
                This will reassign products to new bins. Current bin assignments will be updated atomicaly in the database.
            </div>
        </div>

        <div id="reorgProgState" style="display:none; padding:2rem 0; text-align:center;">
            <div style="font-size:14px; font-weight:500; color:#0f172a; margin-bottom:12px;">Running DP Knapsack Array Computation...</div>
            <div class="cap-track" style="margin-bottom:8px;">
                <div class="cap-fill" style="width:100%; animation: pulse 1s infinite alternate;"></div>
            </div>
            <div style="font-size:12px; color:#64748b; font-style:italic;">Processing distributed permutations...</div>
        </div>

        <div id="reorgResultState" style="display:none;">
            <div style="background:#f0fdf4; border:1px solid #bbf7d0; padding:1.5rem; border-radius:8px; text-align:center; margin-bottom:1.5rem;">
                <i class="fa-solid fa-circle-check" style="color:#3B6D11; font-size:32px; margin-bottom:12px;"></i>
                <div style="font-size:16px; font-weight:600; color:#0f172a; margin-bottom:16px;">Optimization Complete</div>
                
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; text-align:left; font-size:13px; color:#334155; background:white; padding:12px; border-radius:6px; border:1px solid #e2e8f0;">
                    <div>Bins Re-Packed:</div><strong id="optBins" style="text-align:right;">--</strong>
                    <div>Items Moved:</div><strong id="optItems" style="text-align:right;">--</strong>
                    <div>Efficiency Gain:</div><strong id="optGain" style="text-align:right; color:#3B6D11;">--</strong>
                    <div>Compute Time:</div><strong id="optTime" style="text-align:right; color:#64748b;">--</strong>
                </div>
            </div>
            <button style="background:#378ADD; color:white; width:100%; padding:11px; border:none; border-radius:8px; font-size:14px; font-weight:500; cursor:pointer;" onclick="window.location.reload()">Done & Refresh Data</button>
        </div>
    </div>
</div>

<style>
/* Utilities for animating the loading bar */
@keyframes pulse {
    0% { transform: scaleX(0); transform-origin: left; }
    100% { transform: scaleX(1); transform-origin: left; }
}
</style>

<script>
// --- GLOBAL MODAL CONTROLS ---
const modals = ['addModal', 'searchModal', 'reorgModal'];
function openModal(id) {
    document.getElementById(id).style.display = 'flex';
    if(id === 'reorgModal') fetchReorgPreStats();
}
function closeModal(id) {
    document.getElementById(id).style.display = 'none';
    if(id === 'addModal') {
        document.getElementById('dashSingleForm').reset();
        document.getElementById('dashSingleResult').style.display = 'none';
        document.getElementById('dashSpPreview').style.display = 'none';
        document.getElementById('dashCsvResult').style.display = 'none';
        document.getElementById('dashCsvPreviewWrap').style.display = 'none';
        document.getElementById('dashCsvSubmitBtn').style.display = 'none';
        document.getElementById('dashCsvFileName').style.display = 'none';
        document.getElementById('dashWhCapBar').style.display = 'none';
        document.getElementById('dashCsvFileInput').value = '';
        _dashCsvRows = [];
    }
    if(id === 'searchModal') {
        document.getElementById('searchForm').reset();
        document.getElementById('searchFoundList').style.display = 'none';
        document.getElementById('searchNotFound').style.display = 'none';
        document.getElementById('searchEmpty').style.display = 'block';
    }
}
window.onclick = function(event) {
    modals.forEach(m => {
        const md = document.getElementById(m);
        if (event.target == md && (!isReorgRunning || m !== 'reorgModal')) closeModal(m);
    });
}
document.addEventListener('keydown', function(event) {
    if (event.key === "Escape") modals.forEach(m => { if(!isReorgRunning || m !== 'reorgModal') closeModal(m); });
});


// ==========================================
// FEATURE 1: ADD PRODUCT — WAREHOUSE DROPDOWN + SINGLE/CSV TABS
// ==========================================
let _dashWhData = []; // Cached warehouse data from API
let _dashCsvRows = [];

function openDashAddModal() {
    document.getElementById('addModal').style.display = 'flex';
    dashSwitchTab('single');
    loadDashWarehouses();
}

async function loadDashWarehouses() {
    const sel = document.getElementById('dashWhSelect');
    try {
        const res = await fetch('/warehouse/list').then(r => r.json());
        if (res.success && res.warehouses.length > 0) {
            _dashWhData = res.warehouses;
            sel.innerHTML = '<option value="">— Select a warehouse —</option>';
            res.warehouses.forEach(w => {
                const opt = document.createElement('option');
                opt.value = w.id;
                opt.textContent = `${w.name}  (${w.utilPercent}% full, ${w.freeBins} bins free)`;
                sel.appendChild(opt);
            });
        } else {
            sel.innerHTML = '<option value="">No warehouses found — create one first</option>';
        }
    } catch(e) {
        sel.innerHTML = '<option value="">Error loading warehouses</option>';
    }
}

function onDashWhChange() {
    const sel = document.getElementById('dashWhSelect');
    const wid = sel.value;
    document.getElementById('dashSpWarehouseId').value = wid;

    const capBar = document.getElementById('dashWhCapBar');
    if (!wid) { capBar.style.display = 'none'; return; }

    const w = _dashWhData.find(x => String(x.id) === String(wid));
    if (!w) { capBar.style.display = 'none'; return; }

    const pct = w.utilPercent;
    const fillColor = pct > 85 ? 'var(--danger)' : pct > 60 ? 'var(--warning)' : 'var(--primary-accent)';
    document.getElementById('dashWhCapFill').style.width = pct + '%';
    document.getElementById('dashWhCapFill').style.background = fillColor;
    document.getElementById('dashWhCapPct').textContent = pct + '%';
    document.getElementById('dashWhCapLabel').textContent = pct > 85 ? 'Critical' : pct > 60 ? 'Moderate' : 'Healthy';
    document.getElementById('dashWhAvailSpace').textContent = w.availableSpace.toFixed(2) + ' m³';
    document.getElementById('dashWhFreeBins').textContent = w.freeBins;
    capBar.style.display = 'block';

    // Update predictive preview if size/qty already entered
    updateDashSpacePreview();
}

function dashSwitchTab(tab) {
    const isSingle = tab === 'single';
    document.getElementById('dashPanelSingle').style.display = isSingle ? 'block' : 'none';
    document.getElementById('dashPanelCSV').style.display = isSingle ? 'none' : 'flex';
    document.getElementById('dashTabSingle').className = isSingle ? 'btn-primary' : 'btn-outlined';
    document.getElementById('dashTabCSV').className   = isSingle ? 'btn-outlined' : 'btn-primary';
}

// ── Live space estimation ──────────────────────────────────────
function updateDashSpacePreview() {
    const size = parseFloat(document.getElementById('dashSpSize').value) || 0;
    const qty  = parseInt(document.getElementById('dashSpQty').value) || 0;
    const req  = size * qty;
    const prev = document.getElementById('dashSpPreview');

    if (req > 0) {
        document.getElementById('dashSpSpaceVal').textContent = req.toFixed(3) + ' m³';
        // Show available space for selected warehouse
        const wid = document.getElementById('dashSpWarehouseId').value;
        const w   = _dashWhData.find(x => String(x.id) === String(wid));
        if (w) {
            document.getElementById('dashSpAvailVal').textContent = w.availableSpace.toFixed(2) + ' m³';
            const fits = req <= w.availableSpace;
            document.getElementById('dashSpFitMsg').textContent = fits
                ? '✓ Fits — Knapsack resolver will find best bin automatically.'
                : '⚠ Exceeds available space in this warehouse.';
            document.getElementById('dashSpFitMsg').style.color = fits ? '#16a34a' : '#dc2626';
        } else {
            document.getElementById('dashSpAvailVal').textContent = '— (select warehouse)';
        }
        prev.style.display = 'block';
    } else {
        prev.style.display = 'none';
    }
}
['dashSpSize', 'dashSpQty'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', updateDashSpacePreview);
});

// ── Single product submit ──────────────────────────────────────
async function dashSubmitSingleProduct() {
    const name     = document.getElementById('dashSpName').value.trim();
    const sku      = document.getElementById('dashSpSku').value.trim();
    const qty      = parseInt(document.getElementById('dashSpQty').value) || 0;
    const priority = document.getElementById('dashSpPriority').value;
    const size     = parseFloat(document.getElementById('dashSpSize').value) || 0;
    const weight   = parseFloat(document.getElementById('dashSpWeight').value) || 0;
    const wid      = document.getElementById('dashSpWarehouseId').value;

    if (!wid) { dashShowSingleResult('error', 'Please select a warehouse first.'); return; }
    if (!name || qty < 1 || size <= 0) { dashShowSingleResult('error', 'Please fill in Name, Quantity, and Size.'); return; }

    const btn = event.target;
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Allocating via Knapsack...';

    try {
        const r = await fetch('/inventory/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, sku, quantity: qty, priority, size, weight, warehouse_id: wid })
        });
        const data = await r.json();
        if (data.success) {
            dashShowSingleResult('success', `✓ "${name}" added to Bin ${data.binAssigned}. Space remaining: ${parseFloat(data.remainingSpace).toFixed(2)} m³`);
            document.getElementById('dashSingleForm').reset();
            document.getElementById('dashSpPreview').style.display = 'none';
            document.getElementById('dashWhCapBar').style.display = 'none';
            document.getElementById('dashSpWarehouseId').value = '';
            document.getElementById('dashWhSelect').value = '';
            _dashWhData = [];
            loadDashWarehouses();
            setTimeout(() => window.location.reload(), 2000);
        } else {
            dashShowSingleResult('error', '✗ ' + (data.error || 'Could not add product'));
        }
    } catch(e) {
        dashShowSingleResult('error', '✗ Network error: ' + e.message);
    }
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-arrow-right-to-bracket"></i> Add to Warehouse';
}

function dashShowSingleResult(type, msg) {
    const el = document.getElementById('dashSingleResult');
    el.style.display = 'block';
    el.style.background  = type === 'success' ? '#f0fdf4' : '#fef2f2';
    el.style.color       = type === 'success' ? '#166534' : '#991b1b';
    el.style.border      = '1px solid ' + (type === 'success' ? '#bbf7d0' : '#fecaca');
    el.textContent = msg;
}

// ── CSV Upload ─────────────────────────────────────────────────
const dashDropZone  = document.getElementById('dashCsvDropZone');
const dashFileInput = document.getElementById('dashCsvFileInput');

dashDropZone.addEventListener('dragover', e => { e.preventDefault(); dashDropZone.classList.add('drag-over'); });
dashDropZone.addEventListener('dragleave', () => dashDropZone.classList.remove('drag-over'));
dashDropZone.addEventListener('drop', e => {
    e.preventDefault();
    dashDropZone.classList.remove('drag-over');
    const file = e.dataTransfer.files[0];
    if (file) dashHandleCSVFile(file);
});
dashFileInput.addEventListener('change', () => {
    if (dashFileInput.files[0]) dashHandleCSVFile(dashFileInput.files[0]);
});

function dashHandleCSVFile(file) {
    document.getElementById('dashCsvFileName').style.display = 'block';
    document.getElementById('dashCsvFileNameText').textContent = file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB)';
    const reader = new FileReader();
    reader.onload = e => dashParseCSVPreview(e.target.result);
    reader.readAsText(file);
}

function dashParseCSVPreview(text) {
    const lines = text.trim().split('\n').filter(l => l.trim());
    if (lines.length < 2) { dashShowCSVResult('error', 'CSV must have a header row + at least one data row.'); return; }

    const headers = lines[0].split(',').map(h => h.trim().toLowerCase());
    _dashCsvRows = [];
    for (let i = 1; i < lines.length; i++) {
        const vals = lines[i].split(',').map(v => v.trim());
        const row = {};
        headers.forEach((h, idx) => row[h] = vals[idx] || '');
        _dashCsvRows.push(row);
    }

    const head = document.getElementById('dashCsvPreviewHead');
    head.innerHTML = headers.map(h => `<th style="padding:6px 10px;text-align:left;text-transform:uppercase;font-size:11px;color:var(--text-muted);border-bottom:1px solid var(--border-color);">${h}</th>`).join('');
    const body = document.getElementById('dashCsvPreviewBody');
    body.innerHTML = _dashCsvRows.slice(0, 5).map(row =>
        `<tr>${headers.map(h => `<td style="padding:6px 10px;border-bottom:1px solid #f1f5f9;font-size:12px;">${row[h] || '—'}</td>`).join('')}</tr>`
    ).join('');
    document.getElementById('dashCsvPreviewWrap').style.display = 'block';
    document.getElementById('dashCsvSubmitBtn').style.display = 'block';
    dashShowCSVResult('info', `${_dashCsvRows.length} rows detected. Click Upload to begin allocation.`);
}

function dashShowCSVResult(type, msg) {
    const el = document.getElementById('dashCsvResult');
    el.style.display = 'block';
    const colors = {
        success: ['#f0fdf4','#166534','#bbf7d0'],
        error:   ['#fef2f2','#991b1b','#fecaca'],
        info:    ['#EFF6FF','#1e40af','#bfdbfe']
    };
    const [bg, col, border] = colors[type] || colors.info;
    el.style.background = bg; el.style.color = col; el.style.border = `1px solid ${border}`;
    el.textContent = msg;
}

async function dashSubmitCSV() {
    const wid = document.getElementById('dashSpWarehouseId').value;
    if (!wid) { dashShowCSVResult('error', 'Please select a warehouse in the dropdown above.'); return; }
    if (!_dashCsvRows.length) return;

    const btn = document.getElementById('dashCsvSubmitBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Uploading...';

    try {
        const r = await fetch('/inventory/bulk-add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rows: _dashCsvRows, warehouse_id: wid })
        });
        const data = await r.json();
        if (data.success) {
            let msg = `✓ ${data.added} product(s) added.`;
            if (data.skipped > 0) msg += ` ${data.skipped} skipped (warehouse mismatch or no space).`;
            if (data.errors && data.errors.length) msg += '\nSkip reasons: ' + data.errors.slice(0, 3).join('; ');
            dashShowCSVResult('success', msg);
            document.getElementById('dashCsvSubmitBtn').style.display = 'none';
            setTimeout(() => window.location.reload(), 2000);
        } else {
            dashShowCSVResult('error', '✗ ' + (data.error || 'Upload failed'));
        }
    } catch(e) {
        dashShowCSVResult('error', '✗ Network error: ' + e.message);
    }
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-cloud-arrow-up"></i> Upload & Allocate All Products';
}




// ==========================================
// FEATURE 2: HASH MAP SEARCH & RETRIEVE
// ==========================================
document.getElementById('searchForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const q = document.getElementById('searchInput').value.trim();
    if(!q) return;

    document.getElementById('searchEmpty').style.display = 'none';
    document.getElementById('searchNotFound').style.display = 'none';
    document.getElementById('searchFoundList').style.display = 'none';
    document.getElementById('searchLoader').style.display = 'block';
    document.getElementById('searchFoundList').innerHTML = ''; // Clear prev

    try {
        const rs = await fetch('/inventory/search?q=' + encodeURIComponent(q));
        const res = await rs.json();
        
        document.getElementById('searchLoader').style.display = 'none';

        if(res.found && res.products && res.products.length > 0) {
            document.getElementById('searchFoundList').style.display = 'flex';
            
            res.products.forEach(p => {
                let badgeStyle = "background:#fffbeb; color:#854F0B;"; // medium
                if(p.priority == 2 || p.priority === 'High') { badgeStyle = "background:#fef2f2; color:#A32D2D;"; }
                else if(p.priority == 0 || p.priority === 'Low') { badgeStyle = "background:#f0fdf4; color:#3B6D11;"; }
                
                const wname = p.warehouse_name || p.warehouse || `Warehouse-${p.warehouse_id||'?'}`;

                const card = document.createElement('div');
                card.style.cssText = "border:1px solid #e2e8f0; border-radius:8px; overflow:hidden;";
                card.innerHTML = `
                    <div style="background:#f8fafc; padding:12px 16px; border-bottom:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
                        <div>
                            <div style="font-weight:600; font-size:15px; color:#0f172a;">${p.name} <span style="font-weight:400; font-size:12px; color:#64748b;">(in ${wname})</span></div>
                        </div>
                        <div class="ls-badge" style="${badgeStyle}">${p.priority == 2 || p.priority === 'High' ? 'High Prio' : 'Priority'}</div>
                    </div>
                    <div style="padding:16px; display:grid; grid-template-columns:1fr 1fr; gap:12px; font-size:13px; color:#64748b;">
                        <div>SKU: <strong style="color:#0f172a;">${p.sku}</strong></div>
                        <div>Quantity: <strong style="color:#0f172a;">${p.quantity}</strong></div>
                        <div>Weight: <strong style="color:#0f172a;">${p.weight || '--'} kg</strong></div>
                        <div>Total Size: <strong style="color:#0f172a;">${(parseFloat(p.size)*parseInt(p.quantity)).toFixed(1)} sqft</strong></div>
                    </div>
                    <div style="background:#E6F1FB; padding:12px 16px; display:flex; justify-content:space-between; align-items:center; border-top:1px solid #e2e8f0;">
                        <div style="font-size:13px; color:#185FA5; font-weight:600;">
                            <i class="fa-solid fa-location-dot"></i> Rack ${p.rack_number||p.rack_id||'--'} | Bin ${p.bin_number||p.bin_id||'--'}
                        </div>
                        <button onclick="confirmRetrieve(${p.product_id}, ${p.warehouse_id || 'null'}, ${p.bin_id || p.bin_number}, '${p.name}', ${p.quantity}, '${wname}')" 
                                style="background:#A32D2D; color:white; border:none; border-radius:6px; padding:6px 12px; font-size:12px; font-weight:500; cursor:pointer; display:flex; align-items:center; gap:6px;">
                            <i class="fa-solid fa-trash-can"></i> Retrieve Stock
                        </button>
                    </div>
                `;
                document.getElementById('searchFoundList').appendChild(card);
            });
            
        } else {
            document.getElementById('searchNotFound').style.display = 'block';
        }
    } catch(e) {
        document.getElementById('searchLoader').style.display = 'none';
        alert("Hash Lookup Error.");
    }
});

async function confirmRetrieve(product_id, warehouse_id, bin_id, name, qty, wname) {
    if(!confirm(`WARNING:\nYou are retrieving ALL ${qty} units of '${name}' out of physically mapped Bin ${bin_id} in ${wname}.\n\nThe records will be securely removed. Proceed?`)) return;
    
    try {
        const payload = { product_id, warehouse_id, bin_id };
        const response = await fetch('/inventory/retrieve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const result = await response.json();
        if(result.success) {
            closeModal('searchModal');
            showToast(`Retrieved ${qty} items from Bin ${bin_id}`);
            setTimeout(()=>window.location.reload(), 1500);
        } else {
            alert("Retrieve Failed: " + result.error);
        }
    } catch(err) {
        alert("Network Error during retrieve.");
    }
}


// ==========================================
// FEATURE 3: REORGANIZE DP KNAPSACK
// ==========================================
let isReorgRunning = false;

async function fetchReorgPreStats() {
    // Basic endpoint fetching total bins and items
    try {
        const rs = await fetch('/warehouse/stats');
        const js = await rs.json();
        if(js) {
            document.getElementById('reorgProdCount').innerText = js.totalProducts || 0;
            document.getElementById('reorgBinCount').innerText = js.totalBins || 0;
            document.getElementById('reorgUtil').innerText = (js.utilPercent || 0) + "%";
        }
    } catch(e) {
        document.getElementById('reorgProdCount').innerText = "--";
        document.getElementById('reorgBinCount').innerText = "--";
        document.getElementById('reorgUtil').innerText = "--";
    }
}

async function executeReorg() {
    isReorgRunning = true;
    document.getElementById('reorgPreState').style.display = 'none';
    document.getElementById('reorgProgState').style.display = 'block';

    try {
        const t0 = Date.now();
        const response = await fetch('/warehouse/reorganize', { method: 'POST' });
        const result = await response.json();
        const tEnd = Date.now() - t0;

        document.getElementById('reorgProgState').style.display = 'none';

        if(result.success) {
            document.getElementById('optBins').innerText = result.binsOptimized;
            document.getElementById('optItems').innerText = result.productsReallocated;
            document.getElementById('optGain').innerText = "+" + (result.efficiencyGain || 0) + "%";
            document.getElementById('optTime').innerText = (result.timeTaken || tEnd) + "ms";
            document.getElementById('reorgResultState').style.display = 'block';
        } else {
            alert("Optimization failed computing DP Array: " + result.error);
            resetReorgLayer();
        }
    } catch(e) {
        alert("Server unreachable.");
        resetReorgLayer();
    }
}
function resetReorgLayer() {
    isReorgRunning = false;
    document.getElementById('reorgProgState').style.display = 'none';
    document.getElementById('reorgResultState').style.display = 'none';
    document.getElementById('reorgPreState').style.display = 'block';
}

function showToast(msg) {
    const d = document.createElement('div');
    d.innerText = msg;
    d.style.position = 'fixed'; d.style.bottom = '20px'; d.style.right = '20px';
    d.style.background = '#0f172a'; d.style.color = '#fff'; d.style.padding = '12px 20px';
    d.style.borderRadius = '8px'; d.style.zIndex = 10000; d.style.fontSize = '14px';
    document.body.appendChild(d);
    setTimeout(()=>d.remove(), 3000);
}
</script>

<%- include('partials/header.ejs') %>
<title>Inventory | StockMate</title>

<style>
.inv-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
}
.page-header h1 {
    font-size: 20px;
    font-weight: 500;
    margin: 0;
    color: var(--text-primary);
}
.page-header p {
    font-size: 13px;
    color: var(--text-muted);
    margin: 3px 0 0;
}

/* Summary strip */
.summary-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
}
.sum-card {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 14px;
}
.sum-icon {
    width: 38px; height: 38px;
    background: #EFF6FF;
    color: var(--primary-accent);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
}
.sum-val  { font-size: 20px; font-weight: 500; color: var(--text-primary); }
.sum-label{ font-size: 12px; color: var(--text-muted); margin-top: 1px; }

/* Toolbar */
.toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    gap: 12px;
}
.toolbar-left { display: flex; gap: 10px; flex-grow: 1; flex-wrap: wrap; }
.search-wrapper { position: relative; flex: 1; max-width: 320px; }
.search-wrapper input {
    width: 100%; padding: 9px 12px 9px 36px;
    border: 1px solid var(--border-color);
    border-radius: 8px; font-size: 14px;
    box-sizing: border-box; outline: none; background: white;
    color: var(--text-primary);
}
.search-wrapper input:focus { border-color: var(--primary-accent); }
.search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 13px; }
.filter-select {
    padding: 9px 12px;
    border: 1px solid var(--border-color);
    border-radius: 8px; font-size: 13px;
    color: var(--text-secondary); background: white; cursor: pointer; outline: none;
}

/* Table */
.table-card { background: white; border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden; }
table { width: 100%; border-collapse: collapse; }
th {
    background: #f8fafc; color: var(--text-secondary);
    font-weight: 500; font-size: 12px; text-align: left;
    padding: 12px 16px; border-bottom: 1px solid var(--border-color);
    text-transform: uppercase; letter-spacing: 0.4px;
    white-space: nowrap;
}
td { padding: 14px 16px; font-size: 14px; color: var(--text-primary); border-bottom: 1px solid var(--border-color); }
tbody tr { transition: background 150ms ease; }
tbody tr:hover { background: #f8fafc; }
tbody tr:last-child td { border-bottom: none; }

.badge { padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 500; display: inline-block; }
.badge-high   { background: #fef2f2; color: var(--danger); }
.badge-medium { background: #fffbeb; color: var(--warning); }
.badge-low    { background: #f0fdf4; color: var(--success); }

.wh-pill {
    display: inline-flex; align-items: center; gap: 5px;
    background: #f1f5f9; color: var(--text-secondary);
    border-radius: 6px; padding: 3px 8px;
    font-size: 12px; font-weight: 500;
}
.location-pill {
    display: inline-flex; align-items: center; gap: 5px;
    background: #EFF6FF; color: #185FA5;
    border-radius: 6px; padding: 3px 8px;
    font-size: 12px; font-weight: 500;
}

.empty-state { text-align: center; padding: 5rem 2rem; color: var(--text-muted); }
.empty-icon  { font-size: 48px; margin-bottom: 1rem; opacity: 0.25; }
</style>

<div class="inv-container">

    <div class="page-header">
        <div>
            <h1>Inventory</h1>
            <p>All products across your warehouses</p>
        </div>
        <div style="display:flex; gap:10px;">
            <a href="/warehouse" class="btn-outlined" style="text-decoration:none; font-size:13px; padding:8px 16px;">
                <i class="fa-solid fa-warehouse"></i> My Warehouses
            </a>
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="summary-strip">
        <div class="sum-card">
            <div class="sum-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
            <div>
                <div class="sum-val"><%= totalProducts %></div>
                <div class="sum-label">Total Products</div>
            </div>
        </div>
        <div class="sum-card">
            <div class="sum-icon" style="background:#fff7ed; color:var(--warning);"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div>
                <div class="sum-val" style="color:<%= lowStock > 0 ? 'var(--warning)' : 'var(--text-primary)' %>"><%= lowStock %></div>
                <div class="sum-label">Low Stock (≤10 units)</div>
            </div>
        </div>
        <div class="sum-card">
            <div class="sum-icon" style="background:#f0fdf4; color:var(--success);"><i class="fa-solid fa-check-circle"></i></div>
            <div>
                <div class="sum-val" style="color:var(--success);"><%= totalProducts - lowStock %></div>
                <div class="sum-label">Healthy Stock</div>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-wrapper">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" id="searchInput" placeholder="Search by product name, warehouse, rack...">
            </div>
            <select class="filter-select" id="priorityFilter">
                <option value="">Priority: All</option>
                <option value="High">High</option>
                <option value="Medium">Medium</option>
                <option value="Low">Low</option>
            </select>
            <select class="filter-select" id="stockFilter">
                <option value="">Stock: All</option>
                <option value="low">Low Stock (≤10)</option>
                <option value="ok">In Stock</option>
            </select>
        </div>
        <span style="font-size:13px; color:var(--text-muted);">
            <span id="visibleCount"><%= totalProducts %></span> items
        </span>
    </div>

    <!-- Table -->
    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Qty</th>
                    <th>Priority</th>
                    <th>Warehouse</th>
                    <th>Location</th>
                    <th>Size (m²)</th>
                    <th>Weight (kg)</th>
                    <th>Added</th>
                </tr>
            </thead>
            <tbody id="productTable">
            <% if (products && products.length > 0) { %>
                <% products.forEach(function(p, i) {
                    const prio = p.priorityLabel || 'Medium';
                    const badgeClass = prio === 'High' ? 'badge-high' : prio === 'Low' ? 'badge-low' : 'badge-medium';
                    const addedDate = p.inserted_at ? new Date(p.inserted_at).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}) : '—';
                    const isLowStock = p.quantity <= 10;
                    const searchText = (p.name + ' ' + (p.warehouse_name||'') + ' ' + (p.rack_name||'')).toLowerCase();
                %>
                <tr 
                  data-priority="<%= prio %>"
                  data-stock="<%= isLowStock ? 'low' : 'ok' %>"
                  data-text="<%= searchText %>"
                >
                    <td style="color:var(--text-muted); font-size:12px;"><%= String(i+1).padStart(2,'0') %></td>
                    <td><strong><%= p.name %></strong></td>
                    <td>
                        <span style="font-weight:500; <%= isLowStock ? 'color:var(--danger);' : '' %>"><%= p.quantity %></span>
                        <% if(isLowStock) { %><span style="font-size:11px; color:var(--warning); margin-left:4px;">⚠ low</span><% } %>
                    </td>
                    <td><span class="badge <%= badgeClass %>"><%= prio %></span></td>
                    <td>
                        <a href="/inventory/<%= p.warehouse_id %>" style="text-decoration:none;">
                            <span class="wh-pill">
                                <i class="fa-solid fa-warehouse" style="font-size:10px;"></i>
                                <%= p.warehouse_name %>
                            </span>
                        </a>
                    </td>
                    <td>
                        <span class="location-pill">
                            <i class="fa-solid fa-location-dot" style="font-size:10px;"></i>
                            <%= p.rack_name || ('Rack ' + p.rack_id) %> &bull; Bin <%= p.bin_id %>
                        </span>
                    </td>
                    <td style="color:var(--text-secondary); font-size:13px;"><%= p.size || '—' %></td>
                    <td style="color:var(--text-secondary); font-size:13px;"><%= p.weight || '—' %></td>
                    <td style="color:var(--text-muted); font-size:12px;"><%= addedDate %></td>
                </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="9">
                        <div class="empty-state">
                            <div class="empty-icon"><i class="fa-solid fa-box-open"></i></div>
                            <div style="font-size:17px; font-weight:500; color:var(--text-primary); margin-bottom:8px;">No products yet</div>
                            <div style="font-size:13px; line-height:1.7;">
                                You haven't added any products to your warehouses.<br>
                                Go to the <a href="/dashboard" style="color:var(--primary-accent);">Dashboard</a> and click <strong>Add Product</strong>.
                            </div>
                        </div>
                    </td>
                </tr>
            <% } %>
            </tbody>
        </table>

        <% if(products && products.length > 0) { %>
        <div style="padding:12px 16px; border-top:1px solid var(--border-color); font-size:13px; color:var(--text-secondary); display:flex; justify-content:space-between;">
            <span>Showing <strong id="shownCount"><%= products.length %></strong> of <strong><%= products.length %></strong> items</span>
        </div>
        <% } %>
    </div>
</div>

<script>
    const searchInput    = document.getElementById('searchInput');
    const priorityFilter = document.getElementById('priorityFilter');
    const stockFilter    = document.getElementById('stockFilter');
    const rows = document.querySelectorAll('#productTable tr[data-text]');

    function filterTable() {
        const q     = searchInput.value.toLowerCase();
        const prio  = priorityFilter.value;
        const stock = stockFilter.value;
        let visible = 0;
        rows.forEach(row => {
            const textOk  = !q     || row.dataset.text.includes(q);
            const prioOk  = !prio  || row.dataset.priority === prio;
            const stockOk = !stock || row.dataset.stock === stock;
            const show = textOk && prioOk && stockOk;
            row.style.display = show ? '' : 'none';
            if(show) visible++;
        });
        const vc = document.getElementById('visibleCount');
        const sc = document.getElementById('shownCount');
        if(vc) vc.textContent = visible;
        if(sc) sc.textContent = visible;
    }

    if(searchInput)    searchInput.addEventListener('input', filterTable);
    if(priorityFilter) priorityFilter.addEventListener('change', filterTable);
    if(stockFilter)    stockFilter.addEventListener('change', filterTable);
</script>

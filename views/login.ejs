<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StockMate - Sign In</title>
<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Inter', system-ui, sans-serif;
    }
    body {
        background-color: #f8fafc;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    
    .login-wrapper {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .login-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 2.5rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }

    .card-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 2rem;
    }
    .logo-square {
        width: 28px;
        height: 28px;
        background-color: #378ADD;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
    }
    .logo-txt {
        font-size: 22px;
        font-weight: 500;
        color: #0f172a;
    }
    .logo-sub {
        font-size: 13px;
        color: #64748b;
        margin-top: 4px;
    }

    .error-alert {
        background-color: #fee2e2;
        color: #7f1d1d;
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        font-size: 13px;
        border: 1px solid #fca5a5;
    }
    .error-alert strong { display: block; font-size: 14px; margin-bottom: 4px; }

    .form-group {
        margin-bottom: 1.5rem;
    }
    .form-label {
        display: block;
        font-size: 13px;
        color: #64748b;
        margin-bottom: 6px;
    }
    .flex-label {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }
    .flex-label label {
        font-size: 13px;
        color: #64748b;
    }
    .flex-label a {
        font-size: 13px;
        color: #378ADD;
        text-decoration: none;
    }

    .input-wrapper {
        position: relative;
    }
    .input-wrapper svg {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        width: 16px;
        height: 16px;
        color: #94a3b8;
    }
    .form-input {
        width: 100%;
        padding: 10px 12px 10px 38px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        outline: none;
        transition: border-color 150ms ease;
    }
    .form-input:focus {
        border-color: #378ADD;
    }

    .btn-submit {
        width: 100%;
        padding: 11px;
        background: #378ADD;
        color: #ffffff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: background 150ms ease;
        margin-bottom: 1rem;
    }
    .btn-submit:hover {
        background: #185FA5;
    }

    .signup-row {
        text-align: center;
        font-size: 13px;
        color: #64748b;
    }
    .signup-link {
        color: #378ADD;
        font-weight: 500;
        text-decoration: none;
    }

    .footer-txt {
        font-size: 12px;
        color: #94a3b8;
        text-align: center;
        margin-top: 1.5rem;
    }
</style>
</head>
<body>

<div class="login-wrapper">
    <div class="login-card">
        <div class="card-header">
            <div class="logo-square">
                <!-- Simple Box SVG for Logo -->
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5L5 9V15L12 19L19 15V9L12 5Z"></path>
                </svg>
            </div>
            <div class="logo-txt">StockMate</div>
            <div class="logo-sub">Smart Storage. Zero Waste.</div>
        </div>

        <!-- EJS Errors -->
        <% if (typeof incorrectPass !== 'undefined' && incorrectPass) { %>
        <div class="error-alert">
            <strong>Incorrect password</strong>
            The password entered does not match our records.
        </div>
        <% } else if(typeof userNotFound !== 'undefined' && userNotFound) { %>
        <div class="error-alert">
            <strong>User Not Found</strong>
            The email entered does not match our records. Please sign up.
        </div>
        <% } %>

        <form action="/login" method="POST">
            <div class="form-group">
                <label class="form-label">Email Address</label>
                <div class="input-wrapper">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                        <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    <input type="email" name="email" class="form-input" placeholder="name@company.com" required>
                </div>
            </div>

            <div class="form-group">
                <div class="flex-label">
                    <label>Password</label>
                    <a href="#">Forgot Password?</a>
                </div>
                <div class="input-wrapper">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                    <input type="password" name="password" class="form-input" placeholder="••••••••" required>
                </div>
            </div>

            <button type="submit" class="btn-submit">Sign In</button>
            <div class="signup-row">
                No Account Yet? <a href="/signup" class="signup-link">Sign Up</a>
            </div>
        </form>
    </div>
    
    <div class="footer-txt">StockMate v4.2.0 • Editorial Logistics</div>
</div>

</body>
</html>

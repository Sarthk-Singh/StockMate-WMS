<%- include('partials/header.ejs') %>
<title>StockMate - Sign In</title>

<div class="min-h-screen flex items-center justify-center p-6 selection:bg-primary-fixed selection:text-on-primary-fixed">
    <div class="w-full max-w-md">
        <!-- Auth Card Shell -->
        <div class="bg-surface-container-low rounded-xl p-8 md:p-10 shadow-2xl border border-outline-variant/15">
            <!-- Logo Section -->
            <div class="flex flex-col items-center mb-10">
                <div class="w-14 h-14 micro-gradient-primary rounded-xl flex items-center justify-center mb-4 shadow-sm">
                    <span class="material-symbols-outlined text-white text-3xl" data-icon="inventory_2">inventory_2</span>
                </div>
                <h1 class="text-2xl font-extrabold tracking-tight text-on-surface">StockMate</h1>
                <p class="text-sm font-medium text-on-surface-variant mt-1">Smart Storage. Zero Waste.</p>
            </div>

            <!-- EJS Errors -->
            <% if (typeof incorrectPass !== 'undefined' && incorrectPass) { %>
            <div class="mb-6 p-4 bg-error-container text-on-error-container rounded-lg flex items-start gap-3">
                <span class="material-symbols-outlined text-2xl">error</span>
                <div>
                    <h3 class="text-sm font-bold">Incorrect password</h3>
                    <p class="text-xs mt-1">The password entered does not match our records.</p>
                </div>
            </div>
            <% } else if(typeof userNotFound !== 'undefined' && userNotFound) { %>
            <div class="mb-6 p-4 bg-error-container text-on-error-container rounded-lg flex items-start gap-3">
                <span class="material-symbols-outlined text-2xl">person_off</span>
                <div>
                    <h3 class="text-sm font-bold">User Not Found</h3>
                    <p class="text-xs mt-1">The email entered does not match our records. Please sign up.</p>
                </div>
            </div>
            <% } %>

            <!-- Login Form -->
            <form action="/login" method="POST" class="space-y-6">
                <div class="space-y-4">
                    <!-- Email Field -->
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant px-1" for="email">Email Address</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-xl">mail</span>
                            <input class="w-full pl-10 pr-4 py-3 bg-surface-container border border-outline-variant rounded-xl text-on-surface placeholder:text-outline/60 focus:outline-none focus:ring-2 focus:ring-primary transition-all duration-200" id="email" name="email" placeholder="name@company.com" type="email" required autocomplete="email" />
                        </div>
                    </div>
                    <!-- Password Field -->
                    <div class="space-y-1.5">
                        <div class="flex justify-between items-center px-1">
                            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant" for="password">Password</label>
                            <a class="text-xs font-semibold text-primary hover:text-primary-container transition-colors" href="#">Forgot Password?</a>
                        </div>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-xl">lock</span>
                            <input class="w-full pl-10 pr-12 py-3 bg-surface-container border border-outline-variant rounded-xl text-on-surface placeholder:text-outline/60 focus:outline-none focus:ring-2 focus:ring-primary transition-all duration-200" id="password" name="password" placeholder="••••••••" type="password" required />
                        </div>
                    </div>
                </div>
                <!-- Submit Button -->
                <button class="w-full micro-gradient-primary text-on-primary font-bold py-3.5 rounded-xl btn-pulse shadow-md hover:shadow-lg transition-all" type="submit">
                    Sign In
                </button>
            </form>

            <!-- Secondary Actions -->
            <div class="mt-8 pt-8 border-t border-outline-variant/15 space-y-4">
                <p class="text-center text-sm font-medium text-on-surface-variant">
                    No Account Yet? Start Optimizing Today.
                    <a class="text-primary font-bold hover:underline decoration-2 underline-offset-4" href="/signup">Sign Up</a>
                </p>
            </div>
        </div>

        <!-- Visual Decorative Elements -->
        <div class="mt-12 flex justify-center items-center opacity-30 pointer-events-none">
            <div class="text-[10px] font-bold tracking-tighter text-outline uppercase">
                StockMate v4.2.0 • Editorial Logistics
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer.ejs') %>

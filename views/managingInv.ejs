<%- include('partials/header.ejs') %>

<title>Managing Inventory</title>
<link rel="stylesheet" href="/styles/managingInv.css" />
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
/>
<script src="https://cdn.lordicon.com/lordicon.js"></script>
<div class="main">
  <div class="title">
    <div class="back">
      <a href="/warehouse"><i class="fa-solid fa-arrow-left"></i></a>
    </div>

    <h1>Managing Inventory <span><%= warehouseName %> </span></h1>
    <img src="images/arrowBlue.png" alt="" />
  </div>
  <div class="content">
    <p>
      This allows users to <span>add new products</span> with attributes like
      size, weight, and priority, and automatically assigns them to optimal bins
      using the Knapsack algorithm. Users can also
      <span>search for a product </span>by ID to
      <span>instantly retrieve</span> its storage location and view a real-time
      product list with bin details.
    </p>
  </div>
  <div class="buttons">
    <button id="AddProduct">+ ADD PRODUCT</button>
    <button id="RetrieveProduct">- RETRIVE PRODUCT</button>
  </div>
  <div class="AddLists">
    <a href="/product">See Product List</a>
  </div>

  <!-- --------------------------------------------------- -->

  <!-- Add Items Modal Overlay -->
  <div class="modal-overlay" id="addItemsModal">
    <div class="modal-box">
      <div class="modal-title">
        Add Items to Warehouse
        <button class="close-btn" onclick="closeModals()"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form action="/submit-batch" method="POST" id="addForm" onsubmit="return submitSingleBatch();">
        <input type="hidden" name="products" id="productsData" />
        
        <div class="field-group">
          <label>Product Name</label>
          <input type="text" id="ProductName" autocomplete="off" required />
        </div>

        <div class="field-group">
          <label>SKU</label>
          <input type="text" id="sku" autocomplete="off" />
        </div>

        <div class="field-group">
          <label>Category</label>
          <input type="text" id="category" autocomplete="off" />
        </div>

        <div class="field-group">
          <label>Quantity</label>
          <input type="number" id="quant" autocomplete="off" required />
        </div>

        <div class="field-group">
          <label>Weight (kg)</label>
          <input type="number" id="weight" step="any" autocomplete="off" required />
        </div>

        <div class="field-group">
          <label>Size (sq ft)</label>
          <input type="number" id="size" step="any" max="<%=capacity %>" autocomplete="off" required />
        </div>

        <div class="field-group">
          <label>Priority</label>
          <select id="priority">
            <option value="High">High</option>
            <option value="Normal">Medium</option>
            <option value="Low">Low</option>
          </select>
        </div>

        <button type="submit" class="btn-primary">Submit</button>
        <button type="button" class="btn-secondary" onclick="closeModals()">Cancel</button>
      </form>
    </div>
  </div>


  <!-- Retrieve Items Modal Overlay -->
  <div class="modal-overlay" id="retrieveItemsModal">
    <div class="modal-box">
      <div class="modal-title">
        Retrieve Item
        <button class="close-btn" onclick="closeModals()"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="retrieveForm">
        <div class="field-group">
          <label>Product Name or SKU</label>
          <input type="text" name="productName" placeholder="Enter product name or SKU..." autocomplete="off" required />
        </div>

        <button type="submit" class="btn-primary">Search</button>
      </form>

      <!-- Empty State / Result Container -->
      <div id="retrieveState">
        <div class="empty-state">
          Enter a product name or SKU to locate it instantly
          <span class="small-note">⚡ O(1) Hash Lookup</span>
        </div>
      </div>

      <!-- We will inject the result-card into #retrieveState dynamically -->

      <button type="button" class="btn-secondary" onclick="closeModals()">Cancel</button>
    </div>
  </div>

  <script src="/styles/nn.js"></script>

  <%-include('partials/footer.ejs') %>
</div>

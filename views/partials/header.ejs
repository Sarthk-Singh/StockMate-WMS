<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StockMate</title>
    <!-- Inter Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
    <!-- Global CSS -->
    <link rel="stylesheet" href="/styles/common.css" />
</head>
<body>

<nav class="saas-navbar">
    <div class="nav-left">
        <div class="logo">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="24" height="24" rx="6" fill="#378ADD"/>
                <path d="M12 5L5 9V15L12 19L19 15V9L12 5Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M5 9L12 13L19 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 19V13" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="brand-name">StockMate</span>
        </div>
    </div>
    
    <div class="nav-center">
        <a href="/dashboard" class="nav-link" id="nav-dashboard">Dashboard</a>
        <a href="/product" class="nav-link" id="nav-inventory">Inventory</a>
        <a href="/warehouse" class="nav-link" id="nav-warehouse">Warehouse</a>
        <a href="/settings" class="nav-link" id="nav-settings">Settings</a>
    </div>

    <div class="nav-right">
        <div class="avatar-circle">
            SM
        </div>
    </div>
</nav>

<script>
    // Simple script to highlight active nav
    const path = window.location.pathname;
    document.querySelectorAll('.nav-link').forEach(link => {
        if(link.getAttribute('href') === path || 
          (path.startsWith('/makeInv') && link.getAttribute('id') === 'nav-warehouse') || 
          (path.startsWith('/managingInv') && link.getAttribute('id') === 'nav-inventory')) {
            link.classList.add('active');
        }
    });

    // Temp logic: redirect /settings to somewhere generic since it may not exist yet
    // Avatar click temp listener
    document.querySelector('.avatar-circle').addEventListener('click', () => {
        window.location.href = "/settings";
    });
</script>

<%- include('partials/header.ejs') %>
<title><%= warehouse ? warehouse.name + ' — Inventory' : 'Inventory' %> | StockMate</title>

<style>
.inv-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
}
.inv-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 2rem;
}
.back-btn {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    background: white;
    color: var(--text-primary);
    text-decoration: none;
    flex-shrink: 0;
    transition: background 150ms ease;
}
.back-btn:hover { background: #f1f5f9; }

.stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
}
.stat-card {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1rem 1.25rem;
}
.stat-label { font-size: 11px; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
.stat-val   { font-size: 22px; font-weight: 500; color: var(--primary-accent); }
.stat-sub   { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }

.cap-strip {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 16px;
}
.cap-strip-track { flex: 1; height: 6px; background: #f1f5f9; border-radius: 3px; overflow: hidden; }
.cap-strip-fill  { height: 100%; border-radius: 3px; }

.toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    gap: 12px;
}
.toolbar-left { display: flex; gap: 10px; flex-grow: 1; }
.search-wrapper { position: relative; flex: 1; max-width: 340px; }
.search-wrapper input {
    width: 100%; padding: 9px 12px 9px 36px;
    border: 1px solid var(--border-color);
    border-radius: 8px; font-size: 14px;
    box-sizing: border-box; outline: none; background: white;
}
.search-wrapper input:focus { border-color: var(--primary-accent); }
.search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 13px; }
.filter-select {
    padding: 9px 12px;
    border: 1px solid var(--border-color);
    border-radius: 8px; font-size: 13px;
    color: var(--text-secondary); background: white; cursor: pointer; outline: none;
}

.table-card { background: white; border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden; }
table { width: 100%; border-collapse: collapse; }
th {
    background: #f8fafc; color: var(--text-secondary);
    font-weight: 500; font-size: 12px; text-align: left;
    padding: 12px 16px; border-bottom: 1px solid var(--border-color);
    text-transform: uppercase; letter-spacing: 0.4px;
}
td { padding: 14px 16px; font-size: 14px; color: var(--text-primary); border-bottom: 1px solid var(--border-color); }
tbody tr { transition: background 150ms ease; }
tbody tr:hover { background: #f8fafc; }
tbody tr:last-child td { border-bottom: none; }

.badge { padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 500; display: inline-block; }
.badge-high   { background: #fef2f2; color: var(--danger); }
.badge-medium { background: #fffbeb; color: var(--warning); }
.badge-low    { background: #f0fdf4; color: var(--success); }

.location-pill {
    display: inline-flex; align-items: center; gap: 5px;
    background: #EFF6FF; color: #185FA5;
    border-radius: 6px; padding: 3px 8px;
    font-size: 12px; font-weight: 500;
}

.empty-state { text-align: center; padding: 4rem 2rem; color: var(--text-muted); }
.empty-icon  { font-size: 40px; margin-bottom: 1rem; opacity: 0.3; }

/* ── Manage Modal ─────────────────────────────── */
.modal-backdrop {
    position: fixed; inset: 0;
    background: rgba(15,23,42,0.45);
    display: flex; align-items: center; justify-content: center;
    z-index: 1000;
    opacity: 0; pointer-events: none;
    transition: opacity 150ms ease;
}
.modal-backdrop.open { opacity: 1; pointer-events: all; }
.modal-box {
    background: #fff;
    border-radius: 14px;
    padding: 2rem;
    width: 100%; max-width: 440px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    transform: translateY(12px);
    transition: transform 150ms ease;
}
.modal-backdrop.open .modal-box { transform: translateY(0); }
.modal-title {
    font-size: 17px; font-weight: 600; color: var(--text-primary);
    margin: 0 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
}
.modal-close {
    width: 28px; height: 28px; border-radius: 50%;
    border: none; background: #f1f5f9;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    color: var(--text-secondary); font-size: 13px;
    transition: background 150ms ease;
}
.modal-close:hover { background: #e2e8f0; }
.modal-field { margin-bottom: 1rem; }
.modal-field label { display: block; font-size: 12px; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
.modal-field input, .modal-field select {
    width: 100%; padding: 9px 12px;
    border: 1px solid var(--border-color);
    border-radius: 8px; font-size: 14px;
    color: var(--text-primary); background: white;
    box-sizing: border-box; outline: none;
    transition: border-color 150ms ease;
}
.modal-field input:focus, .modal-field select:focus { border-color: var(--primary-accent); }
.modal-field input[readonly] { background: #f8fafc; color: var(--text-muted); cursor: not-allowed; }
.modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.modal-actions { display: flex; gap: 10px; margin-top: 1.5rem; justify-content: flex-end; }
.btn-manage {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; font-size: 12px; font-weight: 500;
    border: 1px solid var(--primary-accent); color: var(--primary-accent);
    background: transparent; border-radius: 6px; cursor: pointer;
    transition: all 150ms ease;
}
.btn-manage:hover { background: #eff6ff; }
</style>

<div class="inv-container">

    <div class="inv-header">
        <a href="/warehouse" class="back-btn" title="Back to Warehouses">
            <i class="fa-solid fa-arrow-left" style="font-size:13px;"></i>
        </a>
        <div style="flex:1;">
            <h1 style="font-size:20px; font-weight:500; margin:0; color:var(--text-primary);">
                <% if(warehouse) { %><%= warehouse.name %><% } else { %>Inventory<% } %>
            </h1>
            <p style="font-size:13px; color:var(--text-muted); margin:2px 0 0;">Products stored in this warehouse</p>
        </div>
    </div>

    <% if(warehouse) { %>
    <div class="stats-bar">
        <div class="stat-card">
            <div class="stat-label">Products</div>
            <div class="stat-val"><%= products ? products.length : 0 %></div>
            <div class="stat-sub">items allocated</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Racks</div>
            <div class="stat-val"><%= warehouse.rackCount %></div>
            <div class="stat-sub">physical rack units</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Bins</div>
            <div class="stat-val"><%= warehouse.totalBins %></div>
            <div class="stat-sub"><%= warehouse.freeBins %> free</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Utilization</div>
            <div class="stat-val" style="color:<%= warehouse.utilPercent > 85 ? 'var(--danger)' : warehouse.utilPercent > 65 ? 'var(--warning)' : 'var(--primary-accent)' %>">
                <%= warehouse.utilPercent %>%
            </div>
            <div class="stat-sub"><%= warehouse.availSqft %> m³ free</div>
        </div>
    </div>
    <div class="cap-strip">
        <span style="font-size:13px; color:var(--text-secondary); flex-shrink:0;">Capacity</span>
        <div class="cap-strip-track">
            <div class="cap-strip-fill" style="width:<%= warehouse.utilPercent %>%; background:<%= warehouse.utilPercent > 85 ? 'var(--danger)' : warehouse.utilPercent > 65 ? 'var(--warning)' : 'var(--primary-accent)' %>;"></div>
        </div>
        <span style="font-size:13px; font-weight:500; flex-shrink:0;"><%= warehouse.utilPercent %>%</span>
    </div>
    <% } %>

    <div class="toolbar">
        <div class="toolbar-left">
            <div class="search-wrapper">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" id="searchInput" placeholder="Search by name, rack...">
            </div>
            <select class="filter-select" id="priorityFilter">
                <option value="">Priority: All</option>
                <option value="High">High</option>
                <option value="Medium">Medium</option>
                <option value="Low">Low</option>
            </select>
        </div>
        <span style="font-size:13px; color:var(--text-muted);" id="rowCount">
            <% if(products && products.length > 0) { %><%= products.length %> items<% } %>
        </span>
    </div>

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Product Name</th>
                    <th>Qty</th>
                    <th>Priority</th>
                    <th>Location</th>
                    <th>Size (m²)</th>
                    <th>Weight (kg)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="productTable">
            <% if (products && products.length > 0) { %>
                <% products.forEach(function(p, i) {
                    const prio = p.priorityLabel || 'Medium';
                    const badgeClass = prio === 'High' ? 'badge-high' : prio === 'Low' ? 'badge-low' : 'badge-medium';
                    const searchText = (p.name + ' ' + (p.rack_name||'') + ' bin ' + p.bin_id).toLowerCase();
                %>
                <tr data-priority="<%= prio %>" data-text="<%= searchText %>">
                    <td style="color:var(--text-muted); font-size:12px;"><%= String(i+1).padStart(2,'0') %></td>
                    <td><strong><%= p.name %></strong></td>
                    <td>
                        <span style="font-weight:500; <%= p.quantity <= 10 ? 'color:var(--danger);' : '' %>"><%= p.quantity %></span>
                        <% if(p.quantity <= 10) { %><span style="font-size:11px; color:var(--warning); margin-left:4px;">⚠</span><% } %>
                    </td>
                    <td><span class="badge <%= badgeClass %>"><%= prio %></span></td>
                    <td>
                        <span class="location-pill">
                            <i class="fa-solid fa-location-dot" style="font-size:10px;"></i>
                            <%= p.rack_name || ('Rack ' + p.rack_id) %> &bull; Bin <%= p.bin_id %>
                        </span>
                    </td>
                    <td style="color:var(--text-secondary); font-size:13px;"><%= p.size || '—' %></td>
                    <td style="color:var(--text-secondary); font-size:13px;"><%= p.weight || '—' %></td>
                    <td>
                        <button class="btn-manage"
                            data-id="<%= p.product_id %>"
                            data-name="<%= p.name %>"
                            data-quantity="<%= p.quantity %>"
                            data-priority="<%= p.priorityLabel %>"
                            data-size="<%= p.size %>"
                            data-bin="<%= p.bin_id %>">
                            <i class="fa-solid fa-pen-to-square" style="font-size:11px;"></i> Manage
                        </button>
                    </td>
                </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="8">
                        <div class="empty-state">
                            <div class="empty-icon"><i class="fa-solid fa-box-open"></i></div>
                            <div style="font-size:16px; font-weight:500; color:var(--text-primary); margin-bottom:8px;">No products in this warehouse</div>
                            <div style="font-size:13px;">Use <strong>Add Product</strong> on the dashboard to stock this warehouse.</div>
                        </div>
                    </td>
                </tr>
            <% } %>
            </tbody>
        </table>
        <% if(products && products.length > 0) { %>
        <div style="padding:12px 16px; border-top:1px solid var(--border-color); font-size:13px; color:var(--text-secondary);">
            Showing <strong id="visibleCount"><%= products.length %></strong> of <strong><%= products.length %></strong> items
        </div>
        <% } %>
    </div>
</div>

<!-- ── Manage Product Modal ──────────────────────────────── -->
<div id="manageBackdrop" class="modal-backdrop">
    <div class="modal-box">
        <div class="modal-title">
            <span><i class="fa-solid fa-pen-to-square" style="font-size:15px; margin-right:8px; color:var(--primary-accent);"></i>Manage Product</span>
            <button class="modal-close" id="manageClose"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <form action="/inventory/update" method="POST">
            <input type="hidden" name="product_id"   id="m_product_id">
            <input type="hidden" name="bin_id"       id="m_bin_id">
            <input type="hidden" name="size"         id="m_size">
            <input type="hidden" name="warehouse_id" value="<%= warehouse ? warehouse.id : '' %>">

            <div class="modal-field">
                <label>Product Name</label>
                <input type="text" id="m_name" readonly>
            </div>

            <div class="modal-grid">
                <div class="modal-field">
                    <label>Quantity</label>
                    <input type="number" name="quantity" id="m_quantity" min="0" required
                           style="border-color: var(--border-color);">
                </div>
                <div class="modal-field">
                    <label>Priority</label>
                    <select name="priority" id="m_priority">
                        <option value="Low">Low</option>
                        <option value="Medium">Medium</option>
                        <option value="High">High</option>
                    </select>
                </div>
            </div>

            <div class="modal-actions">
                <button type="button" id="manageCancelBtn"
                    style="padding:9px 18px; border:1px solid var(--border-color); border-radius:8px;
                           background:white; font-size:14px; cursor:pointer; color:var(--text-secondary);">
                    Cancel
                </button>
                <button type="submit" class="btn-primary" style="padding:9px 20px; font-size:14px;">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    const searchInput    = document.getElementById('searchInput');
    const priorityFilter = document.getElementById('priorityFilter');
    const rows = document.querySelectorAll('#productTable tr[data-text]');

    function filterTable() {
        const q    = searchInput.value.toLowerCase();
        const prio = priorityFilter.value;
        let visible = 0;
        rows.forEach(row => {
            const textOk = !q    || row.dataset.text.includes(q);
            const prioOk = !prio || row.dataset.priority === prio;
            const show = textOk && prioOk;
            row.style.display = show ? '' : 'none';
            if(show) visible++;
        });
        const vc = document.getElementById('visibleCount');
        if(vc) vc.textContent = visible;
    }

    if(searchInput)    searchInput.addEventListener('input', filterTable);
    if(priorityFilter) priorityFilter.addEventListener('change', filterTable);

    // ── Manage Modal Logic ────────────────────────────────────
    const backdrop     = document.getElementById('manageBackdrop');
    const closeBtn     = document.getElementById('manageClose');
    const cancelBtn    = document.getElementById('manageCancelBtn');

    function openManageModal(btn) {
        document.getElementById('m_product_id').value = btn.dataset.id;
        document.getElementById('m_bin_id').value     = btn.dataset.bin;
        document.getElementById('m_size').value       = btn.dataset.size;
        document.getElementById('m_name').value       = btn.dataset.name;
        document.getElementById('m_quantity').value   = btn.dataset.quantity;
        document.getElementById('m_priority').value   = btn.dataset.priority;
        backdrop.classList.add('open');
    }

    function closeManageModal() {
        backdrop.classList.remove('open');
    }

    document.querySelectorAll('.btn-manage').forEach(btn => {
        btn.addEventListener('click', () => openManageModal(btn));
    });

    closeBtn.addEventListener('click', closeManageModal);
    cancelBtn.addEventListener('click', closeManageModal);

    // Close on backdrop click
    backdrop.addEventListener('click', (e) => {
        if (e.target === backdrop) closeManageModal();
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeManageModal();
    });
</script>

<%- include('partials/header.ejs') %>
<title>Settings | StockMate</title>
<style>
/* Settings Specific Layout Details */
.settings-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 0;
}

.page-header {
    margin-bottom: 2rem;
}
.page-title {
    font-size: 20px;
    font-weight: 500;
}

.settings-layout {
    display: flex;
    gap: 3rem;
}

/* Sidebar Tabs */
.settings-tabs {
    flex: 0 0 240px;
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.tab-btn {
    text-align: left;
    padding: 10px 16px;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 150ms ease;
    display: flex;
    align-items: center;
    gap: 12px;
}
.tab-btn:hover {
    background: #f1f5f9;
    color: var(--text-primary);
}
.tab-btn.active {
    background: #e0f2fe; /* light blue tint */
    color: var(--primary-accent);
}

.logout-form {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
}
.btn-logout {
    background: transparent;
    border: 1px solid #fca5a5;
    color: var(--danger);
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    width: 100%;
    text-align: left;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all 150ms ease;
}
.btn-logout:hover {
    background: #fef2f2;
}

/* Tab Content Areas */
.settings-content {
    flex: 1;
}
.tab-panel {
    display: none;
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
}
.tab-panel.active {
    display: block;
}

.panel-title {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
}

/* Profile Specifics */
.avatar-section {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
}
.avatar-large {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 500;
    color: var(--text-secondary);
}

/* Preferences Specifics */
.toggle-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border-color);
}
.toggle-info strong {
    display: block;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 4px;
}
.toggle-info span {
    font-size: 13px;
    color: var(--text-muted);
}
/* Basic Toggle Switch CSS */
.switch {
  position: relative;
  display: inline-block;
  width: 44px;
  height: 24px;
}
.switch input { 
  opacity: 0;
  width: 0;
  height: 0;
}
.slider {
  position: absolute;
  cursor: pointer;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: #cbd5e1;
  transition: .15s;
  border-radius: 24px;
}
.slider:before {
  position: absolute;
  content: "";
  height: 18px;
  width: 18px;
  left: 3px;
  bottom: 3px;
  background-color: white;
  transition: .15s;
  border-radius: 50%;
}
input:checked + .slider {
  background-color: var(--primary-accent);
}
input:checked + .slider:before {
  transform: translateX(20px);
}
</style>

<div class="settings-container">
    <div class="page-header">
        <div class="page-title">Settings</div>
    </div>

    <div class="settings-layout">
        <!-- Sidebar Navigation -->
        <div class="settings-tabs">
            <button class="tab-btn active" onclick="switchTab('profile')">
                <i class="fa-regular fa-user"></i> Profile & Security
            </button>
            <button class="tab-btn" onclick="switchTab('prefs')">
                <i class="fa-solid fa-sliders"></i> Preferences
            </button>

            <form action="/logout" method="POST" class="logout-form">
                <button type="submit" class="btn-logout">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </button>
            </form>
        </div>

        <!-- Content Area -->
        <div class="settings-content">
            <!-- Profile Tab Panel -->
            <div id="tab-profile" class="tab-panel active">
                <div class="panel-title">Profile & Security</div>

                <% if (typeof success !== 'undefined' && success) { %>
                <div style="background:#dcfce7; border:1px solid #86efac; color:#166534; padding:12px 16px; border-radius:8px; margin-bottom:1.5rem; font-size:14px; display:flex; align-items:center; gap:8px;">
                    <i class="fa-solid fa-circle-check"></i> Profile updated successfully.
                </div>
                <% } %>

                <% if (typeof error !== 'undefined' && error) { %>
                <div style="background:#fef2f2; border:1px solid #fca5a5; color:#991b1b; padding:12px 16px; border-radius:8px; margin-bottom:1.5rem; font-size:14px; display:flex; align-items:center; gap:8px;">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <% if (error === 'wrong_password') { %>Incorrect current password.<% } %>
                    <% if (error === 'passwords_mismatch') { %>New passwords do not match.<% } %>
                    <% if (error === 'all_password_fields_required') { %>Please fill in all password fields.<% } %>
                    <% if (!['wrong_password','passwords_mismatch','all_password_fields_required'].includes(error)) { %>An error occurred. Please try again.<% } %>
                </div>
                <% } %>

                <form action="/settings/update" method="POST">
                <div class="avatar-section">
                    <div class="avatar-large">
                        <%= typeof name !== 'undefined' ? name.substring(0,2).toUpperCase() : 'SM' %>
                    </div>
                    <div>
                        <button type="button" class="btn-outlined" style="padding: 6px 12px;">Upload New Photo</button>
                        <div style="font-size:12px; color:var(--text-muted); margin-top:8px;">At least 256x256px PNG or JPG.</div>
                    </div>
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="fullName" class="form-input" value="<%= typeof name !== 'undefined' ? name : '' %>">
                    </div>
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" class="form-input" value="<%= typeof email !== 'undefined' ? email : '' %>" readonly style="background:#f8fafc; color:var(--text-muted); cursor:not-allowed;">
                    </div>
                </div>

                <div style="margin-top:2rem; margin-bottom:1rem; font-weight:500; font-size:15px;">Update Password</div>
                <div class="form-group">
                    <label>Current Password</label>
                    <input type="password" name="currentPassword" class="form-input" placeholder="Enter current password">
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div class="form-group">
                        <label>New Password</label>
                        <input type="password" id="newPassword" name="newPassword" class="form-input" placeholder="Enter new password">
                    </div>
                    <div class="form-group">
                        <label>Confirm Password</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" placeholder="Confirm new password">
                        <span id="pw-mismatch" style="display:none; font-size:12px; color:#dc2626; margin-top:6px; display:none; align-items:center; gap:4px;">
                            <i class="fa-solid fa-circle-exclamation"></i> New passwords do not match
                        </span>
                    </div>
                </div>

                <div style="margin-top:2rem; text-align:right;">
                    <button type="submit" class="btn-primary">Save Changes</button>
                </div>
                </form>
            </div>

            <!-- Preferences Tab Panel -->
            <div id="tab-prefs" class="tab-panel">
                <div class="panel-title">System Preferences</div>
                
                <div class="form-group" style="max-width:300px; margin-bottom:2rem;">
                    <label>Low Stock Alert Threshold</label>
                    <div style="display:flex; align-items:center; gap:12px;">
                        <input type="number" class="form-input" value="10">
                        <span style="font-size:13px; color:var(--text-muted);">units</span>
                    </div>
                </div>

                <div class="toggle-row">
                    <div class="toggle-info">
                        <strong>Email Alerts</strong>
                        <span>Receive an email when new shipments are processed</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked>
                        <span class="slider"></span>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-info">
                        <strong>Low Stock Warnings</strong>
                        <span>Show a banner in the dashboard when limits are breached</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked>
                        <span class="slider"></span>
                    </label>
                </div>

                <div class="toggle-row" style="border-bottom:none;">
                    <div class="toggle-info">
                        <strong>Weekly Activity Digest</strong>
                        <span>Receive a summary of all warehouse mutations every Friday</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox">
                        <span class="slider"></span>
                    </label>
                </div>

                <div style="margin-top:2.5rem; text-align:right;">
                    <button class="btn-primary">Save Preferences</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function switchTab(tabId) {
        // Reset Tabs
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('active'));
        
        // Activate new tab
        event.currentTarget.classList.add('active');
        document.getElementById('tab-' + tabId).classList.add('active');
    }

    // Live password mismatch validation
    const newPwInput     = document.getElementById('newPassword');
    const confirmPwInput = document.getElementById('confirmPassword');
    const mismatchHint   = document.getElementById('pw-mismatch');
    const saveBtn        = document.querySelector('button[type="submit"].btn-primary');

    function checkPasswords() {
        const newVal     = newPwInput.value;
        const confirmVal = confirmPwInput.value;

        // Only show hint when the user has started typing in confirm field
        if (confirmVal.length === 0) {
            mismatchHint.style.display = 'none';
            saveBtn.disabled = false;
            saveBtn.style.opacity = '';
            return;
        }

        if (newVal !== confirmVal) {
            mismatchHint.style.display = 'flex';
            saveBtn.disabled = true;
            saveBtn.style.opacity = '0.5';
        } else {
            mismatchHint.style.display = 'none';
            saveBtn.disabled = false;
            saveBtn.style.opacity = '';
        }
    }

    newPwInput.addEventListener('input', checkPasswords);
    confirmPwInput.addEventListener('input', checkPasswords);
</script>
</body>
</html>
